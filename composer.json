{
    "name": "mohaaosman/persona-generator",
    "description": "Locale-aware, coherent, seedable persona generator (names, timelines, prose) for candidate seeding.",
    "type": "library",
    "license": "MIT",
    "keywords": ["faker", "persona", "seeding", "laravel", "somali"],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/collections": "^11.0 || ^12.0 || ^13.0",
        "nesbot/carbon": "^2.72 || ^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "laravel/ai": "^0.6"
    },
    "autoload": {
        "psr-4": {
            "PersonaGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PersonaGenerator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PersonaGenerator\\PersonaGeneratorServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
